<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">

    <de.hdodenhof.circleimageview.CircleImageView android:id="@+id/ivAvatar"
        android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_default_avatar" />

    <TextView android:id="@+id/tvUsername" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginStart="12dp" />
</LinearLayout>